{
  "name": "@ekaone/mask-card",
  "version": "1.2.0",
  "description": "A lightweight, zero-dependency TypeScript library for masking credit card numbers",
  "keywords": [
    "credit card",
    "mask",
    "obfuscate",
    "security",
    "mask-visa",
    "mask-mastercard",
    "mask-amex",
    "mask-discover",
    "mask-jcb",
    "mask-diners",
    "mask-elo",
    "mask-mir",
    "mask-rupay",
    "mask-uatp",
    "typescript"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm typecheck && tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ekaone/mask-card"
  },
  "bugs": {
    "url": "https://github.com/ekaone/mask-card/issues"
  },
  "homepage": "https://github.com/ekaone/mask-card#readme",
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "rimraf": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
